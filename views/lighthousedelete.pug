extends layout

block content
  h1= title

  if (toShow == null)
    h2 No instance to delete
  else
    - let lighthouseid = toShow._id
    - let name = toShow.name
    - let location = toShow.location
    - let height = toShow.height
    - let actionid = "/resource/lighthouses/" + lighthouseid

    script.
      let actionid = "#{actionid}"

    div
      div.row
        div(class='lighthouseAttr mr-3') Lighthouse ID is:
        div #{lighthouseid}
      div.row
        div(class='lighthouseAttr mr-3') Lighthouse Name is:
        div #{name}
      div.row
        div(class='lighthouseAttr mr-3') Location is:
        div #{location}
      div.row
        div(class='lighthouseAttr mr-3') Height is:
        div #{height}ft

    button(class="btn btn-danger m-2" onclick="deleteOnid()") Delete
    button(class="btn btn-secondary m-2" onclick="cancel()") Cancel

  script.
    function cancel() {
      // Go back to the home page for the lighthouse collection
      window.location.href='/lighthouses'
    }

  script.
    function deleteOnid() {
      console.log("starting delete")
      // delete first
      fetch(actionid, {
        method: 'DELETE'      // Don't need a body for the delete
      }).then((resp) => {
        return resp.json(); // or resp.text() or whatever the server sends
      }).then((body) => {
        alert("Delete succeeded")
        window.location.href='/lighthouses'
        // TODO handle body
      }).catch((error) => {
        // TODO handle error
        alert("Delete failed " + error )
      });
    }